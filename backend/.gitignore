# --- BLOQUEO TOTAL DE CONTENIDO ---
# Ignora todo el contenido de frontend
frontend/**/*

# --- EXCEPCIONES (Si quieres que se vea algo mínimo) ---
# Si quieres que la carpeta aparezca en GitHub aunque esté vacía,
# necesitas que tenga al menos un archivo. 
# Lo estándar es NO ignorar el archivo README.md si existe.
!frontend/README.md

# --- EL BACKEND SE QUEDA COMPLETO ---
!backend/
!backend/**

# --- REGLAS DE LIMPIEZA ---
.env
**/venv/
**/__pycache__/